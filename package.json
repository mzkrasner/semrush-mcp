{
  "name": "semrush-mcp",
  "version": "0.2.0",
  "description": "Semrush MCP server and CLI — unified keyword, domain, and backlink research",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "semrush-mcp": "./dist/index.js",
    "semrush": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run semrush-api.test.ts",
    "test:integration": "vitest run semrush-api.integration.test.ts mcp.integration.test.ts",
    "test:spec": "vitest run api-spec.integration.test.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "qa": "npm run format:check && npm run lint && npm run type-check && npm run test && npm run build",
    "qa:quick": "npm run lint && npm run type-check"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "dotenv": "^16.3.1",
    "node-cache": "^5.1.2",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-sonarjs": "^3.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.3",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
